{
  "name": "oxlint-config",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "lint:code": "turbo lint:code",
    "lint:type": "turbo lint:type",
    "version": "changeset",
    "version:apply": "changeset version",
