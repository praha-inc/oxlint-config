    "version:prepublish": "pkg-pr-new publish --pnpm --compact './packages/*'"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@tsconfig/strictest": "2.0.8",
    "oxlint": "1.69.0",
    "pkg-pr-new": "0.0.75",
    "turbo": "2.9.16",
    "vitest": "4.1.8"
  },
  "packageManager": "pnpm@11.5.2"
}
