    "version:prepublish": "pkg-pr-new publish --pnpm --compact './packages/*'"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.30.0",
    "@tsconfig/strictest": "2.0.8",
    "oxlint": "1.60.0",
    "pkg-pr-new": "0.0.66",
    "turbo": "2.8.14",
    "vitest": "4.0.18"
  },
  "packageManager": "pnpm@10.31.0"
}
