{
  "name": "@praha/oxlint-config-react",
  "version": "1.0.0-beta.5",
  "description": "Oxlint config for PrAha.",
  "keywords": [
    "javascript",
    "typescript",
    "oxlint"
  ],
  "homepage": "https://github.com/praha-inc/oxlint-config/blob/main/packages/react/README.md",
  "bugs": {
    "url": "https://github.com/praha-inc/oxlint-config/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/praha-inc/oxlint-config.git",
    "directory": "packages/react"
  },
  "license": "MIT",
  "author": "PrAha, Inc.",
  "sideEffects": false,
  "type": "module",
  "exports": {
    "require": {
      "types": "./dist/cjs/index.d.ts",
      "default": "./dist/cjs/index.cjs"
    },
    "import": {
      "types": "./dist/esm/index.d.ts",
      "default": "./dist/esm/index.js"
    }
  },
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "rslib build",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "lint:code": "oxlint",
    "lint:type": "tsc --noEmit"
  },
  "dependencies": {
    "@praha/oxlint-config-internal": "workspace:*",
    "eslint-plugin-storybook": "^10.2.19"
  },
  "devDependencies": {
    "@praha/oxlint-config-standard": "workspace:*",
    "@rslib/core": "0.21.3",
    "oxlint": "1.61.0",
    "oxlint-tsgolint": "0.21.1",
    "typescript": "5.9.3",
    "vitest": "4.1.4"
  },
  "peerDependencies": {
    "oxlint": "^1.0.0",
    "oxlint-tsgolint": ">=0.20.0",
    "storybook": "^10.3.5"
  },
  "publishConfig": {
    "provenance": true
  }
}
